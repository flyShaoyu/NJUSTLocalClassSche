{
  "name": "classsche",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript project for fetching and parsing timetable HTML.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json",
