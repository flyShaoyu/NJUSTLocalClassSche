    "render:ui": "tsx src/render-ui.ts",
    "export:android": "tsx src/export-android.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
